# ============================================
# Forensic Security Scanner - Configuration
# ============================================

# --------------------------------------------
# Bitcoin Core RPC Settings
# --------------------------------------------
BITCOIN_RPC_HOST=localhost
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=your_secure_password_here

# --------------------------------------------
# Database Settings
# --------------------------------------------
# Option 1: SQLite (default, simpler)
DB_TYPE=sqlite
SQLITE_PATH=data/forensic_scanner.db

# Option 2: PostgreSQL (better performance for large datasets)
# DB_TYPE=postgresql
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=forensic_scanner
# PG_USER=scanner
# PG_PASSWORD=scanner_password

# --------------------------------------------
# Scanner Settings
# --------------------------------------------
# Block range to scan (default: Genesis to end of 2014)
START_BLOCK=0
END_BLOCK=336000

# Batch size for processing
BATCH_SIZE=1000
MAX_WORKERS=4

# Memory cache size (number of signatures to keep in memory)
CACHE_SIZE=100000

# --------------------------------------------
# Logging Settings
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/forensic_scanner.log

# --------------------------------------------
# Analysis Settings
# --------------------------------------------
# Enable/disable specific modules
ENABLE_SIGNATURE_ANALYSIS=true
ENABLE_BRAINWALLET_SCAN=true
ENABLE_SCRIPT_ANALYSIS=true
ENABLE_FORENSIC_ANALYSIS=true

# Nonce analysis settings
NONCE_SMALL_THRESHOLD=18446744073709551616  # 2^64
NONCE_REUSE_DETECTION=true

# Brain wallet settings
WORDLIST_DIR=wordlists
BRAINWALLET_BATCH_SIZE=10000

# Forensic settings
CLUSTERING_MIN_LINKS=3
